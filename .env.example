# ================================================================
# VERCEL DEPLOYMENT — set ALL of these in:
#   Vercel Dashboard → Your Project → Settings → Environment Variables
# ================================================================

# --- Required ---
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/logistics
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-chars

# Your frontend Vercel URL (e.g. https://elogistica.vercel.app)
# Comma-separate multiple origins if needed
FRONTEND_URL=https://your-frontend.vercel.app

NODE_ENV=production

# --- Recommended ---
JWT_EXPIRES_IN=7d

# --- Notifications (optional) ---
AT_API_KEY=
AT_USERNAME=sandbox
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_WHATSAPP_NUMBER=
EMAIL_USER=
EMAIL_PASS=
GRAPHHOPPER_KEY=

# ================================================================
# LOCAL DEVELOPMENT ONLY — not needed on Vercel
# ================================================================
PORT=5001
# BACKEND_URL=http://localhost:5001
# SMOKE_PASSWORD=SmokePass123!
